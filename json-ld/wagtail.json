    "description": "Open-source; commercial support and services available."
  },
  "hasPart": [
    {
      "@type": "WebAPI",
      "name": "Wagtail API v2",
      "description": "The Wagtail REST API v2 exposes site content — pages, images, documents, and redirects — as JSON. Supports filtering, search, field selection, and pagination.",
      "url": "https://docs.wagtail.org/en/latest/advanced_topics/api/v2/usage.html",
      "documentation": "https://docs.wagtail.org/en/latest/advanced_topics/api/",
      "potentialAction": [
        {
          "@type": "SearchAction",
          "name": "List Pages",
          "urlTemplate": "https://{your-wagtail-site}/api/v2/pages/?{query}"
        },
        {
          "@type": "SearchAction",
          "name": "List Images",
          "urlTemplate": "https://{your-wagtail-site}/api/v2/images/?{query}"
        },
        {
          "@type": "SearchAction",
          "name": "List Documents",
          "urlTemplate": "https://{your-wagtail-site}/api/v2/documents/?{query}"
        }
      ]
    }
  ],
  "keywords": [
